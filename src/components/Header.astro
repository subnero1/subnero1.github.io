---
const { currentPath = '/' } = Astro.props;
import subneroLogo from '@assets/images/subnero-logo.svg';
import { Icon } from 'astro-icon/components';

---

<script>
  // Mobile menu toggle functionality
  function initMobileMenu() {
    const button = document.querySelector('[data-mobile-menu-btn]');
    const mobileMenu = document.querySelector('[data-mobile-menu]');
    
    if (!button || !mobileMenu) return;
    
    button.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
      button.classList.toggle('menu-open');
    });
  }
  
  document.addEventListener('DOMContentLoaded', initMobileMenu);
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>

<header class="sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm">
  <nav class="max-w-7xl mx-auto px-6">
    
    <div class="flex items-center justify-between h-24">
      
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3">
        <img 
          src={subneroLogo.src} 
          alt="Company Logo" 
          class="size-20"
        >
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-x-8">
        <a href="/" class="nav-link ${currentPath === '/' ? 'active' : ''}">Home</a>
        
        <!-- Products Dropdown -->
        <div class="relative group">
          <button class="nav-link flex items-center gap-1">
            Products
            <Icon name="chevron-down" class="w-4 h-4 transition-transform group-hover:rotate-180" />
          </button>
          <div class="absolute pt-2 w-64 hidden group-hover:block" >
            <div class="bg-white rounded-xl shadow-xl border border-gray-100 py-3">
              <a href="/products" class="block px-6 py-2.5 hover:bg-gray-50">WNC Series</a>
                <div class="pl-3">
                  <a href="/products/#smart-modems" class="block px-6 py-2.5 hover:bg-gray-50">Smart Modems</a>
                  <a href="/products/#unetstack" class="block px-6 py-2.5 hover:bg-gray-50">UnetStack</a>
                </div>
              <a href="/products/swis" class="block px-6 py-2.5 hover:bg-gray-50">SWIS Products</a>
                <div class="pl-3">
                  <a href="/products/swis/#adcp-edition" class="block px-6 py-2.5 hover:bg-gray-50">ADCP Edition</a>
                </div>
            </div>
          </div>
        </div>

        <a href="/solutions" class="nav-link ${currentPath === '/solutions' ? 'active' : ''}">Solutions</a>
        <a href="/pulse" class="nav-link ${currentPath.startsWith('/pulse') ? 'active' : ''}">Pulse</a>
        <a href="/user-stories" class="nav-link ${currentPath.startsWith('/user-stories') ? 'active' : ''}">User Stories</a>

        <!-- Resources Dropdown -->
        <div class="relative group">
          <button class="nav-link flex items-center gap-1">
            Resources
            <Icon name="chevron-down" class="w-4 h-4 transition-transform group-hover:rotate-180" />
          </button>
          <div class="absolute pt-2 w-48 hidden group-hover:block">
            <div class="bg-white rounded-xl shadow-xl border border-gray-100 py-3">
              <a href="/support" class="block px-6 py-2.5 hover:bg-gray-50">Support</a>
              <a href="/faq" class="block px-6 py-2.5 hover:bg-gray-50">FAQ</a>
              <a href="/technical-resources" class="block px-6 py-2.5 hover:bg-gray-50">Technical Resources</a>
            </div>
          </div>
        </div>

        <!-- About Dropdown -->
        <div class="relative group" >
          <button class="nav-link flex items-center gap-1">
            About
            <Icon name="chevron-down" class="w-4 h-4 transition-transform group-hover:rotate-180" />
          </button>
          <div class="absolute pt-2 w-48 hidden group-hover:block">
            <div class="bg-white rounded-xl shadow-xl border border-gray-100 py-3">
              <a href="/company" class="block px-6 py-2.5 hover:bg-gray-50">Company</a>
              <a href="/careers" class="block px-6 py-2.5 hover:bg-gray-50">Careers</a>
              <a href="/contact" class="block px-6 py-2.5 hover:bg-gray-50">Contact</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Mobile Hamburger -->
      <button 
        data-mobile-menu-btn
        class="md:hidden p-2 rounded-lg hover:bg-gray-100 focus:outline-none"
        aria-label="Toggle menu">
        <Icon name="menu" class="icon-menu w-6 h-6" />
        <Icon name="x" class="icon-x w-6 h-6" />
      </button>
    </div>

    <!-- Mobile Menu -->
    <div data-mobile-menu class="md:hidden border-t py-6 bg-white hidden">
      <div class="px-6 space-y-5 text-lg">
        <a href="/" class="block">Home</a>
        
        <div>
          <button @click="open = !open" class="flex items-center justify-between w-full">
            <span>Products</span>
            <Icon name="chevron-down" :class="open ? 'rotate-180' : ''" class="w-5 h-5 transition-transform" />
          </button>
          <div class="pl-4 mt-3 space-y-3 text-base text-gray-600 border-l-2 border-gray-100">
            <a href="/products" class="block px-6 py-2.5 hover:bg-gray-50">WNC Series</a>
            <div class="pl-3">
              <a href="/products/#smart-modems" class="block px-6 py-2.5 hover:bg-gray-50">Smart Modems</a>
              <a href="/products/#unetstack" class="block px-6 py-2.5 hover:bg-gray-50">UnetStack</a>
            </div>
            <a href="/products/swis" class="block px-6 py-2.5 hover:bg-gray-50">SWIS Products</a>
            <div class="pl-3">
              <a href="/products/swis/#adcp-edition" class="block px-6 py-2.5 hover:bg-gray-50">ADCP Edition</a>
            </div>
          </div>
        </div>

        <a href="/solutions" class="block">Solutions</a>
        <a href="/pulse" class="block">Pulse</a>
        <a href="/user-stories" class="block">User Stories</a>

        <div class="pt-6 border-t">
          <p class="font-semibold text-gray-500 mb-3">Resources</p>
          <a href="/support" class="block px-6 py-2.5 hover:bg-gray-50">Support</a>
          <a href="/faq" class="block px-6 py-2.5 hover:bg-gray-50">FAQ</a>
          <a href="/technical-resources" class="block px-6 py-2.5 hover:bg-gray-50">Technical Resources</a>
        </div>

        <div class="pt-6 border-t">
          <p class="font-semibold text-gray-500 mb-3">About</p>
          <a href="/company" class="block px-6 py-2.5 hover:bg-gray-50">Company</a>
          <a href="/careers" class="block px-6 py-2.5 hover:bg-gray-50">Careers</a>
          <a href="/contact" class="block px-6 py-2.5 hover:bg-gray-50">Contact</a>
        </div>
      </div>
    </div>
  </nav>
</header>

<style scoped>
  [data-mobile-menu-btn] .icon-menu {
    @apply block;
  }
  [data-mobile-menu-btn] .icon-x {
    @apply hidden;
  }
  [data-mobile-menu-btn].menu-open .icon-menu {
    @apply hidden;
  }
    [data-mobile-menu-btn].menu-open .icon-x {
    @apply block;
  }
</style>