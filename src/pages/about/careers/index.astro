---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const jobs = await getCollection('careers');
---

<BaseLayout title="Careers | Subnero">
  <div class="max-w-7xl mx-auto px-6 py-20">
    <div class="max-w-3xl mb-16">
      <h1 class="text-4xl font-bold mb-6 text-gray-900">Careers</h1>
      <p class="text-xl text-gray-600">
        Lorem ipsum dolor sit amet consectetur adipisicing elit. Provident cupiditate natus quo beatae quidem a iure rerum tenetur incidunt modi minima autem, sed ad quae qui fugit voluptate perferendis sint?
      </p>
    </div>

    <div class="space-y-6">
      <h2 class="text-2xl font-bold mb-8">Open Positions</h2>
      {jobs.length > 0 ? (
        <div class="grid gap-6">
          {jobs.map(job => (
            <a href={`/about/careers/${job.id}`} class="group p-8 bg-white border border-gray-100 rounded-2xl flex flex-col md:flex-row md:items-center justify-between hover:shadow-md transition-shadow">
              <div>
                <h3 class="text-xl font-bold group-hover:text-blue-600 transition-colors mb-2">{job.data.title}</h3>
                <div class="flex flex-wrap gap-4 text-sm text-gray-500">
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    {job.data.location}
                  </span>
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    {job.data.type}
                  </span>
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                    {job.data.department}
                  </span>
                </div>
              </div>
              <span class="mt-4 md:mt-0 px-6 py-2 border border-gray-200 rounded-full text-sm font-bold group-hover:bg-blue-600 group-hover:text-white group-hover:border-blue-600 transition-all">
                Apply Now
              </span>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-gray-600 italic">No open positions at the moment. Check back later!</p>
      )}
    </div>
  </div>
</BaseLayout>
