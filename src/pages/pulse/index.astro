---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('pulse');
const sortedPosts = posts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout title="Pulse | Subnero News & Updates">
  <div class="max-w-7xl mx-auto px-6 py-20">
    <div class="mb-16">
      <h1 class="text-4xl font-bold mb-4">Pulse</h1>
      <p class="text-xl text-gray-600">The latest news, technology deep dives, and company updates from Subnero.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
      {sortedPosts.map(post => (
        <article class="flex flex-col group">
          <a href={`/pulse/${post.id}`} class="block mb-6 overflow-hidden rounded-2xl aspect-video bg-gray-100">
            <img 
              src={post.data.thumbnail} 
              alt={post.data.title} 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </a>
          <div class="flex-grow">
            <div class="flex items-center gap-3 mb-4">
              <time class="text-sm text-gray-500">
                {post.data.publishDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </time>
            </div>
            <a href={`/pulse/${post.id}`} class="block group-hover:text-blue-600 transition-colors">
              <h2 class="text-2xl font-bold mb-4 leading-tight">{post.data.title}</h2>
            </a>
            <p class="text-gray-600 line-clamp-3 mb-6">{post.data.excerpt}</p>
          </div>
          <a href={`/pulse/${post.id}`} class="text-gray-900 font-bold inline-flex items-center gap-2 group/link">
            Read Article
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover/link:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
