---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('pulse');

const latestPosts = posts
  .sort((a, b) =>
    b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
  )
  .slice(0, 3);
---

<BaseLayout title="Subnero | Home">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <section class="py-20 text-center">
      <h1 class="text-5xl font-extrabold mb-6 text-gray-900">Home page Hero</h1>
      <p class="text-xl text-gray-600 mb-10 max-w-3xl mx-auto">Lorem ipsum dolor sit, amet consectetur adipisicing elit. Minus, aspernatur quam. Sequi, commodi, quisquam aliquid obcaecati.</p>
      <div class="flex justify-center gap-4">
        <a href="/products" class="px-8 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors">Our Products</a>
        <a href="/about/contact" class="px-8 py-3 bg-white border border-gray-200 text-gray-900 font-semibold rounded-lg hover:bg-gray-50 transition-colors">Contact Us</a>
      </div>
    </section>

    <section class="py-16">
      <h2 class="text-3xl font-bold mb-10">Latest from Pulse</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {
          latestPosts.map(post => (
            <a href={`/pulse/${post.id}`} class="group">
              <div class="aspect-video overflow-hidden rounded-xl mb-4 bg-gray-100">
                <img src={post.data.thumbnail} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
              </div>
              <h3 class="text-xl font-bold group-hover:text-blue-600 transition-colors">{post.data.title}</h3>
              <p class="text-gray-600 line-clamp-2 mt-2">{post.data.excerpt}</p>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
