---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Our Products | Subnero">
  <div class="max-w-7xl mx-auto px-6 py-20">
    <h1 class="text-4xl font-bold mb-8">Subnero Products</h1>
    <p class="text-xl text-gray-600 mb-12">Discover our range of software-defined modems and underwater networking equipment.</p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
      <!-- Placeholder for product cards -->
      <div class="border border-gray-100 rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow">
        <div class="w-12 h-12 bg-blue-100 rounded-lg mb-6"></div>
        <h3 class="text-xl font-bold mb-4">WNC Modems</h3>
        <p class="text-gray-600">State-of-the-art software-defined underwater acoustic modems.</p>
      </div>
    </div>
  </div>
</BaseLayout>
