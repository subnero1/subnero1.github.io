---
import Layout from '../../layouts/BaseLayout.astro';
---

<Layout title="Resources | Subnero">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <h1 class="text-4xl font-bold mb-8">Resources</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <a href="/resources/support" class="p-6 bg-white border border-gray-200 rounded-xl hover:shadow-lg transition-shadow">
        <h2 class="text-xl font-bold mb-3">Support</h2>
        <p class="text-gray-600">Get help with your Subnero products and services.</p>
      </a>
      
      <a href="/resources/faq" class="p-6 bg-white border border-gray-200 rounded-xl hover:shadow-lg transition-shadow">
        <h2 class="text-xl font-bold mb-3">FAQ</h2>
        <p class="text-gray-600">Find answers to frequently asked questions.</p>
      </a>
      
      <a href="/resources/technical-resources" class="p-6 bg-white border border-gray-200 rounded-xl hover:shadow-lg transition-shadow">
        <h2 class="text-xl font-bold mb-3">Technical Resources</h2>
        <p class="text-gray-600">Access documentation, whitepapers, and technical specs.</p>
      </a>
    </div>
  </div>
</Layout>
